---
// VideoModal - Global singleton component for video overlay
// Use once per page where YoutubeFacade with openInModal={true} is used

interface Props {
  ctaText?: string;
  ctaUrl?: string;
}

const { ctaText, ctaUrl } = Astro.props;
---

<div id="video-modal-overlay" class="video-modal-overlay">
  <div class="video-modal-wrapper">
    <!-- Close button positioned relative to video -->
    <button class="video-modal-close" aria-label="Close video">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <!-- Video container with border -->
    <div class="video-modal-content">
      <!-- iframe will be injected here by YoutubeFacade -->
    </div>
    {/* CTA Button below video */}
    {ctaText && ctaUrl && (
      <div class="video-modal-cta">
        <a href={ctaUrl} target="_blank" class="shiny-cta shiny-cta-orange video-modal-cta-button">
          <span class="btn-content">
            {ctaText}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
        </a>
      </div>
    )}
  </div>
</div>

<script>
  function initVideoModal() {
    const modal = document.getElementById('video-modal-overlay');
    const modalContent = modal?.querySelector('.video-modal-content');
    const closeBtn = modal?.querySelector('.video-modal-close');

    if (!modal || !modalContent || !closeBtn) return;

    // Close modal function
    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      // Remove iframe after animation
      setTimeout(() => {
        modalContent.innerHTML = '';
      }, 300);
    }

    // Close on button click
    closeBtn.addEventListener('click', closeModal);

    // Close on overlay click (but not on video container)
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Close on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  }

  // Initialize on load and on Astro page transitions
  document.addEventListener('DOMContentLoaded', initVideoModal);
  document.addEventListener('astro:page-load', initVideoModal);
</script>

<style>
  /* Video Modal Overlay */
  .video-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.92);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .video-modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* Wrapper for positioning close button relative to video */
  .video-modal-wrapper {
    position: relative;
    width: 100%;
    max-width: 1100px;
    margin: 0 1.5rem;
  }

  /* Close button - positioned at top right of video */
  .video-modal-close {
    position: absolute;
    top: -3rem;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: white;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .video-modal-close:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.1);
  }

  /* Video container with orange border like Snov.io */
  .video-modal-content {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 1rem;
    overflow: hidden;
    /* Orange gradient border */
    border: 3px solid;
    border-image: linear-gradient(135deg, #f97316 0%, #ea580c 50%, #f97316 100%) 1;
    border-radius: 1rem;
    /* Glow effect */
    box-shadow:
      0 0 0 1px rgba(249, 115, 22, 0.3),
      0 0 30px rgba(249, 115, 22, 0.2),
      0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    transition: transform 0.3s ease;
  }

  .video-modal-overlay.active .video-modal-content {
    transform: scale(1);
  }

  /* Fix for border-radius with border-image (use pseudo-element) */
  .video-modal-content {
    position: relative;
    border: none;
    background: linear-gradient(135deg, #f97316, #ea580c, #f97316) padding-box,
                linear-gradient(135deg, #f97316, #ea580c, #f97316) border-box;
    background-origin: border-box;
    background-clip: padding-box, border-box;
  }

  .video-modal-content::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 3px;
    border-radius: 1rem;
    background: linear-gradient(135deg, #f97316, #ea580c, #f97316);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* CTA Button below video */
  .video-modal-cta {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .video-modal-cta-button {
    width: auto;
    max-width: 400px;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .video-modal-wrapper {
      margin: 0 0.75rem;
    }

    .video-modal-close {
      top: -2.5rem;
      width: 2rem;
      height: 2rem;
    }

    .video-modal-close svg {
      width: 18px;
      height: 18px;
    }

    .video-modal-content {
      border-radius: 0.75rem;
    }

    .video-modal-content::before {
      border-radius: 0.75rem;
      padding: 2px;
    }

    .video-modal-cta {
      margin-top: 1rem;
    }

    .video-modal-cta-button {
      padding: 1rem 1.5rem;
      font-size: 0.875rem;
    }
  }
</style>
