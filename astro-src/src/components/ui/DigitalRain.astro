---
// Digital Rain Background Component - Pure CSS animated particles
// Reduced particle count for better performance (20 total, 15 on mobile)

export interface Props {
  variant?: 'default' | 'gold';
}

const { variant = 'default' } = Astro.props;
---

<div class={`digital-rain${variant === 'gold' ? ' digital-rain--gold' : ''}`} aria-hidden="true">
  <div class="rain-particles">
    {Array.from({ length: 20 }).map(() => (
      <div class="rain-particle"></div>
    ))}
  </div>
</div>

<style>
  /*
   * Override particle color for the default (teal) variant using the design
   * token so it tracks --color-primary instead of a hardcoded hex value.
   * The gold variant keeps its own hardcoded gold color defined in global.css.
   */
  .digital-rain:not(.digital-rain--gold) .rain-particle {
    background: var(--color-primary);
    box-shadow: 0 0 6px 1px rgba(var(--color-primary-rgb) / 0.8);
  }

  .digital-rain:not(.digital-rain--gold) .rain-particle:nth-child(odd) {
    box-shadow: 0 0 8px 2px rgba(var(--color-primary-rgb) / 0.9);
  }

  .digital-rain:not(.digital-rain--gold) .rain-particle:nth-child(3n) {
    box-shadow: 0 0 4px 1px rgba(var(--color-primary-rgb) / 0.6);
  }
</style>
