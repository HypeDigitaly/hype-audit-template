  </style>

  <!-- Form Handler Script with Background Function + Polling -->
  <script is:inline>
    (function() {
      // Helper to get traffic source data from cookie
      function getTrafficSourceData() {
        const match = document.cookie.match(/(^| )hd_traffic_source=([^;]+)/);
        if (match) {
          try {
            return JSON.parse(decodeURIComponent(match[2]));
          } catch { return {}; }
        }
        return {};
      }
      
      const form = document.getElementById('audit-form');
      const submitBtn = document.getElementById('audit-submit-btn');
      const btnText = document.getElementById('audit-btn-text');
      const btnLoading = document.getElementById('audit-btn-loading');
      const btnSpinner = document.getElementById('audit-btn-spinner');
      const formState = document.getElementById('audit-form-state');
      const progressState = document.getElementById('audit-progress');
      const successState = document.getElementById('audit-success');
      const errorMessage = document.getElementById('audit-error');
      const errorText = document.getElementById('audit-error-text');
      
      // Progress elements
      const progressBar = document.getElementById('progress-bar');
      const progressPercent = document.getElementById('progress-percent');
      const progressText = document.getElementById('progress-text');
      const progressInfoNote = document.getElementById('progress-info-note');

      if (!form) return;

      // Detect language from form
      const lang = form.querySelector('input[name="language"]')?.value || 'cs';

      // Status to UI text mapping
      const statusMessages = lang === 'cs' ? {
        'pending': 'Zahajuji audit...',
        'validating': 'Ověřuji zadané údaje...',
        'researching': 'Provádím hloubkový výzkum o Vaší společnosti...',
        'generating': 'Generuji interaktivní HTML report...',
        'storing': 'Ukládám report...',
        'emailing': 'Odesílám email s výsledky...',
        'completed': 'Hotovo!',
        'failed': 'Došlo k chybě'
      } : {
        'pending': 'Starting audit...',
        'validating': 'Validating your data...',
        'researching': 'Conducting deep research on your company...',
        'generating': 'Generating interactive HTML report...',
        'storing': 'Storing report...',
        'emailing': 'Sending email with results...',
        'completed': 'Done!',
        'failed': 'An error occurred'
      };

      // Status to step dot mapping (now 8 dots for granular progress)
      // Progress ranges: 0-10 (1), 10-30 (2), 30-38 (3), 38-46 (4), 46-50 (5), 50-58 (6), 58-80 (7), 80-100 (8)
      const statusToDot = {
        'pending': 1,
        'validating': 2,
        'researching': 3, // Will be dynamically updated based on sub-step
        'generating': 7,
        'storing': 7,
        'emailing': 8,
        'completed': 8,
        'failed': 8
      };
      
      // Sub-step to dot mapping (for granular research progress)
      const subStepToDot = {
        'fetch_branding': 3,
        'search_company_info': 3,
        'search_company_news': 3,
        'search_website': 4,
        'search_technologies': 4,
        'search_company_apps': 5,
        'search_ai_tools': 5,
        'llm_analyzing': 6,
        'building_report': 6
      };

      // Generate UUID for job tracking
      function generateUUID() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
          const r = Math.random() * 16 | 0;
          const v = c === 'x' ? r : (r & 0x3 | 0x8);
          return v.toString(16);
        });
      }

      function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }

      function updateStepDots(activeIndex) {
        for (let i = 1; i <= 8; i++) {
          const dot = document.getElementById('step-dot-' + i);
          if (dot) {
            if (i <= activeIndex) {
              dot.classList.remove('bg-neutral-200');
              dot.classList.add('bg-orange-500');
              // Make current dot slightly larger
              if (i === activeIndex) {
                dot.classList.add('scale-125');
              } else {
                dot.classList.remove('scale-125');
              }
            } else {
              dot.classList.remove('bg-orange-500', 'scale-125');
              dot.classList.add('bg-neutral-200');
            }
          }
        }
      }

      function updateProgressUI(status, progress, statusMessage, currentSubStep, subStepMessage) {
        // Update progress bar
        if (progressBar) {
          progressBar.style.width = progress + '%';
        }
        if (progressPercent) {
          progressPercent.textContent = progress + '%';
        }
        
        // Update status text - prefer sub-step message if available
        if (progressText) {
          progressText.textContent = subStepMessage || statusMessage || statusMessages[status] || statusMessages['pending'];
        }
        
        // Update sub-step label
        const progressSubstep = document.getElementById('progress-substep');
        if (progressSubstep && currentSubStep) {
          // Show step number based on sub-step
          const stepNumber = subStepToDot[currentSubStep] || 1;
          progressSubstep.textContent = lang === 'cs' 
            ? `Krok ${stepNumber}/8` 
            : `Step ${stepNumber}/8`;
        } else if (progressSubstep) {
          progressSubstep.textContent = '';
        }
        
        // Update step dots - use sub-step mapping if in researching phase
        let dotIndex;
        if (status === 'researching' && currentSubStep && subStepToDot[currentSubStep]) {
          dotIndex = subStepToDot[currentSubStep];
        } else {
          dotIndex = statusToDot[status] || 1;
        }
        updateStepDots(dotIndex);
      }

      function setLoading(isLoading) {
        if (isLoading) {
          btnText.classList.add('hidden');
          btnLoading.classList.remove('hidden');
          btnSpinner.classList.remove('hidden');
          submitBtn.disabled = true;
        } else {
          btnText.classList.remove('hidden');
          btnLoading.classList.add('hidden');
          btnSpinner.classList.add('hidden');
          submitBtn.disabled = false;
        }
      }

      // Global variables
      let isSubmitting = false;
      let pollingInterval = null;

      function showProgressState(companyName) {
        formState.classList.add('hidden');
        errorMessage.classList.add('hidden');
        progressState.classList.remove('hidden');
        document.getElementById('audit-form-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
        
        // Reset progress
        updateProgressUI('pending', 0, null);
        
        // Update info note with company name
        if (progressInfoNote) {
          if (lang === 'cs') {
            progressInfoNote.innerHTML = `Právě hledáme informace o ${companyName ? `společnosti <strong>${companyName}</strong>` : 'Vaší společnosti'}. Výsledky obdržíte e-mailem.`;
          } else {
            progressInfoNote.innerHTML = `We are currently searching for information on ${companyName ? `<strong>${companyName}</strong>` : 'your company'}. You will receive the results via email.`;
          }
        }
        
        // Show step dots (8 dots for v3 granular progress)
        for (let i = 1; i <= 8; i++) {
          const dot = document.getElementById('step-dot-' + i);
          if (dot) {
            dot.style.opacity = '1';
            // Reset all dots to neutral except first
            if (i === 1) {
              dot.classList.add('bg-orange-500');
              dot.classList.remove('bg-neutral-200');
            } else {
              dot.classList.remove('bg-orange-500');
              dot.classList.add('bg-neutral-200');
            }
          }
        }
        
        // Clear sub-step label
        const progressSubstep = document.getElementById('progress-substep');
        if (progressSubstep) progressSubstep.textContent = '';
      }

      function showError(message) {
        stopPolling();
        progressState.classList.add('hidden');
        formState.classList.remove('hidden');
        errorText.textContent = message;
        errorMessage.classList.remove('hidden');
        errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setLoading(false);
      }

      function hideError() {
        errorMessage.classList.add('hidden');
      }

      function showValidationErrors(validationErrors) {
        stopPolling();
        
        // Hide progress, show form
        progressState.classList.add('hidden');
        formState.classList.remove('hidden');
        setLoading(false);
        
        // Clear previous field errors
        document.querySelectorAll('.field-error').forEach(el => el.remove());
        document.querySelectorAll('.field-error-border').forEach(el => {
          el.classList.remove('field-error-border', 'border-red-500', '!border-red-500');
        });
        
        let firstErrorField = null;
        
        // Show errors for each invalid field
        for (const [fieldName, validation] of Object.entries(validationErrors)) {
          if (!validation.isValid && validation.errorMessage) {
            const field = document.querySelector(`[name="${fieldName}"]`);
            if (field) {
              // Add red border
              field.classList.add('field-error-border', '!border-red-500');
              
              // Add error message below field
              const errorEl = document.createElement('p');
              errorEl.className = 'field-error text-red-500 text-sm mt-1 flex items-start gap-2';
              errorEl.innerHTML = '<iconify-icon icon="solar:danger-triangle-bold" class="text-base mt-0.5 flex-shrink-0"></iconify-icon><span>' + validation.errorMessage + '</span>';
              field.parentNode.appendChild(errorEl);
              
              if (!firstErrorField) {
                firstErrorField = field;
              }
            }
          }
        }
        
        // Scroll to first error
        if (firstErrorField) {
          firstErrorField.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(() => {
            firstErrorField.focus();
          }, 500);
        }
      }

      function showSuccess() {
        stopPolling();
        progressState.classList.add('hidden');
        formState.classList.add('hidden');
        successState.classList.remove('hidden');
        document.getElementById('audit-form-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function stopPolling() {
        if (pollingInterval) {
          clearInterval(pollingInterval);
          pollingInterval = null;
        }
      }

      // Poll for job status
      async function pollJobStatus(jobId) {
        const maxAttempts = 300; // 5 minutes max (300 * 1000ms = 300s)
        let attempts = 0;
        let consecutiveErrors = 0;
        const maxConsecutiveErrors = 5;
        
        return new Promise((resolve, reject) => {
          pollingInterval = setInterval(async () => {
            attempts++;
            
            if (attempts > maxAttempts) {
              stopPolling();
              reject(new Error(lang === 'cs' 
                ? 'Časový limit vypršel. Zkontrolujte prosím svůj email.' 
                : 'Timeout reached. Please check your email.'));
              return;
            }
            
            try {
              const response = await fetch(`/.netlify/functions/audit-status?jobId=${jobId}`);
              const data = await response.json();
              
              consecutiveErrors = 0; // Reset on success
              
              console.log(`[Poll] Status: ${data.status}, Progress: ${data.progress}%, SubStep: ${data.currentSubStep || 'none'}`);
              
              // Update UI with current status (v3: includes sub-step tracking)
              updateProgressUI(
                data.status, 
                data.progress, 
                data.statusMessage,
                data.currentSubStep,
                data.subStepMessage
              );
              
              // Check for completion
              if (data.status === 'completed') {
                stopPolling();
                resolve(data);
                return;
              }
              
              // Check for failure
              if (data.status === 'failed') {
                stopPolling();
                if (data.validationErrors) {
                  reject({ validationErrors: data.validationErrors });
                } else {
                  reject(new Error(data.error || (lang === 'cs' ? 'Audit selhal.' : 'Audit failed.')));
                }
                return;
              }
              
            } catch (error) {
              consecutiveErrors++;
              console.error(`[Poll] Error (attempt ${attempts}):`, error);
              
              if (consecutiveErrors >= maxConsecutiveErrors) {
                stopPolling();
                reject(new Error(lang === 'cs' 
                  ? 'Nepodařilo se získat stav auditu. Zkontrolujte email.' 
                  : 'Failed to get audit status. Please check your email.'));
              }
            }
          }, 1500); // Poll every 1.5 seconds
        });
      }

      // Clear field error when user starts typing or changes selection
      const formFields = form.querySelectorAll('input, textarea, select');
      formFields.forEach(field => {
        const eventType = field.tagName === 'SELECT' ? 'change' : 'input';
        field.addEventListener(eventType, function() {
          if (this.classList.contains('field-error-border')) {
            this.classList.remove('field-error-border', '!border-red-500');
            const errorMsg = this.parentNode.querySelector('.field-error');
            if (errorMsg) {
              errorMsg.remove();
            }
          }
        });
      });

      // Pain point checkbox handling
      const painPointHidden = document.getElementById('biggestPainPoint');
      const painPointOtherCheck = document.getElementById('painpoint-other-check');
      const painPointOtherText = document.getElementById('painpoint-other-text');
      const painPointContainer = document.getElementById('painpoint-container');

      // Map checkbox values to human-readable text for the LLM
      const painPointLabels = {
        'new_customers': lang === 'cs' ? 'Získávání nových zákazníků' : 'Gaining new customers',
        'automating_outreach': lang === 'cs' ? 'Automatizace oslovování' : 'Automating outreach',
        'inbound_leads': lang === 'cs' ? 'Příchozí poptávky a leady' : 'Inbound leads',
        'speed_to_lead': lang === 'cs' ? 'Rychlost reakce na poptávky' : 'Speed to lead',
        'automating_communication': lang === 'cs' ? 'Automatizace komunikace' : 'Automating communication',
        'boring_admin': lang === 'cs' ? 'Nudná administrativa' : 'Boring administrative work',
        'juggling_tools': lang === 'cs' ? 'Přepínání mezi mnoha nástroji' : 'Juggling between many software tools',
        'integrating_ai': lang === 'cs' ? 'Integrace AI do CRM/ERP/aplikace' : 'Integrating AI into CRM/ERP/app',
        'marketing_materials': lang === 'cs' ? 'Tvorba marketingových materiálů' : 'Creating marketing materials',
        'social_media': lang === 'cs' ? 'Postování na sociální sítě' : 'Posting on social media'
      };

      function updatePainPointValue() {
        // Collect all checked pain point checkboxes
        const checkedPainPoints = form.querySelectorAll('input[name="painPointCheckbox"]:checked');
        const painPointValues = Array.from(checkedPainPoints).map(cb => painPointLabels[cb.value] || cb.value);

        // Add "other" text if checked and filled
        if (painPointOtherCheck && painPointOtherCheck.checked && painPointOtherText && painPointOtherText.value.trim()) {
          painPointValues.push(painPointOtherText.value.trim());
        }

        // Update hidden field with comma-separated values
        painPointHidden.value = painPointValues.join(', ');

        // Clear error styling if at least one is selected
        if (painPointValues.length > 0 && painPointContainer) {
          painPointContainer.classList.remove('field-error-container');
        }
      }

      // Add event listeners to all pain point checkboxes
      const painPointCheckboxes = form.querySelectorAll('input[name="painPointCheckbox"]');
      painPointCheckboxes.forEach(cb => {
        cb.addEventListener('change', updatePainPointValue);
      });

      // Handle "other" checkbox and text field
      if (painPointOtherCheck) {
        painPointOtherCheck.addEventListener('change', updatePainPointValue);
      }
      if (painPointOtherText) {
        painPointOtherText.addEventListener('input', updatePainPointValue);
        // Auto-check the "other" checkbox when typing
        painPointOtherText.addEventListener('focus', function() {
          if (painPointOtherCheck) painPointOtherCheck.checked = true;
        });
      }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Prevent double submissions
        if (isSubmitting) {
          console.log('[Form] Submission already in progress, ignoring duplicate');
          return;
        }
        isSubmitting = true;
        
        hideError();

        // Ensure pain point hidden field is updated before submission
        if (typeof updatePainPointValue === 'function') {
          updatePainPointValue();
        }

        const formData = new FormData(form);
        
        // Collect all checked tools
        const toolsCheckboxes = form.querySelectorAll('input[name="toolsCheckbox"]:checked');
        const toolsArray = Array.from(toolsCheckboxes).map(cb => cb.value);
        
        // Add "other" tool if specified
        const otherCheck = document.getElementById('tools-other-check');
        const otherText = document.getElementById('tools-other-text');
        if (otherCheck && otherCheck.checked && otherText && otherText.value.trim()) {
          toolsArray.push(otherText.value.trim());
        }
        
        // Generate unique job ID
        const jobId = generateUUID();
        
        const trafficSource = getTrafficSourceData();
        const data = {
          jobId: jobId,
          email: formData.get('email'),
          website: formData.get('website'),
          companyName: formData.get('companyName'),
          city: formData.get('city'),
          biggestPainPoint: formData.get('biggestPainPoint') || '',
          currentTools: toolsArray.join(', ') || '',
          language: formData.get('language') || 'cs',
          leadSource: 'audit-page-form', // Track that this came from dedicated audit page
          // Traffic source tracking
          utmSource: trafficSource.utmSource,
          utmMedium: trafficSource.utmMedium,
          utmCampaign: trafficSource.utmCampaign,
          utmContent: trafficSource.utmContent,
          utmTerm: trafficSource.utmTerm,
          gclid: trafficSource.gclid,
          fbclid: trafficSource.fbclid,
          msclkid: trafficSource.msclkid,
          referrer: trafficSource.referrer
        };

        // Client-side validation for required fields
        const requiredFields = ['email', 'website', 'companyName', 'city'];
        for (const field of requiredFields) {
          if (!data[field]) {
            showError(lang === 'cs' ? 'Vyplňte prosím všechna povinná pole.' : 'Please fill in all required fields.');
            isSubmitting = false;
            return;
          }
        }

        // Validate pain point (at least one must be selected)
        if (!data.biggestPainPoint) {
          showError(lang === 'cs' ? 'Vyberte prosím alespoň jednu výzvu, kterou řešíte.' : 'Please select at least one challenge you face.');
          if (painPointContainer) {
            painPointContainer.classList.add('field-error-container');
            painPointContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          isSubmitting = false;
          return;
        }

        // Show progress UI immediately
        showProgressState(data.companyName);

        try {
          console.log('[Form] Starting audit with jobId:', jobId);
          
          // =======================================================================
          // STEP 1: Call Background Function (returns 202 immediately)
          // =======================================================================
          console.log('[Form] Calling background function...');
          
          const backgroundResponse = await fetch('/.netlify/functions/audit-background', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          // Background function returns 202 Accepted
          // 404 means endpoint doesn't exist yet - fall back to sync function
          if (backgroundResponse.status === 404) {
            console.warn('[Form] Background function not found (404) - falling back to sync audit');
            
            // Fall back to the old sync function
            const syncResponse = await fetch('/.netlify/functions/audit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });
            
            let syncResult;
            try {
              syncResult = await syncResponse.json();
            } catch {
              syncResult = { success: true };
            }
            
            if (syncResponse.status === 400 && syncResult.validationErrors) {
              showValidationErrors(syncResult.validationErrors);
              isSubmitting = false;
              return;
            }
            
            if (syncResponse.status >= 400 && syncResult.error) {
              showError(syncResult.error);
              isSubmitting = false;
              return;
            }
            
            // Success with sync function
            updateProgressUI('completed', 100, null);
            await sleep(500);
            showSuccess();
            isSubmitting = false;
            return;
          }

          console.log('[Form] Background function accepted (202). Starting polling...');

          // =======================================================================
          // STEP 2: Poll for Status Until Complete
          // =======================================================================
          try {
            // Small delay to let the job initialize
            await sleep(500);
            
            const result = await pollJobStatus(jobId);
            
            console.log('[Form] Audit completed successfully!', result);
            
            // Show completion state
            updateProgressUI('completed', 100, null);
            await sleep(500);
            showSuccess();
            
          } catch (pollError) {
            console.error('[Form] Polling error:', pollError);
            
            if (pollError.validationErrors) {
              showValidationErrors(pollError.validationErrors);
            } else {
              showError(pollError.message || (lang === 'cs' 
                ? 'Došlo k chybě. Zkontrolujte prosím email.' 
                : 'An error occurred. Please check your email.'));
            }
          }
          
          isSubmitting = false;

        } catch (error) {
          console.error('[Form] Unexpected error:', error);
          showError(lang === 'cs' 
            ? 'Došlo k neočekávané chybě. Zkuste to prosím znovu.' 
            : 'An unexpected error occurred. Please try again.');
          isSubmitting = false;
        }
      });
    })();
  </script>
</PageLayout>
