      /**
       * Aggregate a single-value field into chart-ready labels + values.
       *
       * For ordinal/single types the raw counts come from countField().
       * - orderedKeys present  => iterate in that order, include zeros.
       * - orderedKeys null     => groupWithFallback (when labelMap has entries)
       *                          then sortedByFreqDesc.
       * Entries keyed 'Neuvedeno' or '' are excluded from chart output but
       * their respondents still count toward the denominator.
       *
       * @param {Array}  leads - full lead array already filtered to this form
       * @param {Object} qDef  - question definition from FORM_REGISTRY
       * @returns {{ labels: string[], values: number[], totalResponded: number }}
       */
      QuestionView.aggregateSingleField = function(leads, qDef) {
        var raw = countField(leads, qDef.key);
        var hasLabelMap = Object.keys(qDef.labelMap).length > 0;
        var leadIndex = indexLeadsByField(leads, qDef.key);

        var orderedKeys, orderedValues;

        if (qDef.orderedKeys) {
          // Ordinal path — use explicit key order, include zeros for absent keys
          orderedKeys   = qDef.orderedKeys;
          orderedValues = qDef.orderedKeys.map(function(k) { return raw[k] || 0; });
        } else {
          // Frequency-sorted path
          var counts;
          if (hasLabelMap) {
            var knownKeys = Object.keys(qDef.labelMap).filter(function(k) {
              return k !== 'Neuvedeno';
            });
            counts = groupWithFallback(raw, knownKeys, qDef.labelMap);
          } else {
            // No labelMap — copy raw, strip Neuvedeno / empty
            counts = {};
            Object.keys(raw).forEach(function(k) {
              if (k !== 'Neuvedeno' && k !== '') {
                counts[k] = raw[k];
              }
            });
          }
          var sorted = sortedByFreqDesc(counts);
          orderedKeys   = sorted.keys;
          orderedValues = sorted.values;
        }

        // Build human-readable labels, filter out Neuvedeno / empty
        var labels = [];
        var values = [];
        var respondents = new Map();
        orderedKeys.forEach(function(k, i) {
          if (k === 'Neuvedeno' || k === '') return;
          var displayLabel = qDef.labelMap[k] || k;
          labels.push(displayLabel);
          values.push(orderedValues[i]);
          respondents.set(displayLabel, leadIndex.get(k) || []);
        });

        // totalResponded = leads that have a real, non-empty value
        var totalResponded = leads.reduce(function(sum, lead) {
          var v = lead[qDef.key];
          if (v && v !== '' && v !== 'Neuvedeno') return sum + 1;
          return sum;
        }, 0);

        return { labels: labels, values: values, totalResponded: totalResponded, respondents: respondents };
      };

      /**
       * Aggregate a multi-value (array) field into chart-ready labels + values.
       *
       * Uses countArrayField() which already skips null/empty array entries.
       * groupWithFallback applied when labelMap has entries.
       * Results sorted by frequency descending.
       *
       * @param {Array}  leads
       * @param {Object} qDef
       * @returns {{ labels: string[], values: number[], totalResponded: number }}
       */
      QuestionView.aggregateMultiField = function(leads, qDef) {
        var raw = countArrayField(leads, qDef.key);
        var hasLabelMap = Object.keys(qDef.labelMap).length > 0;
        var leadIndex = indexLeadsByArrayField(leads, qDef.key);

        var counts;
        if (hasLabelMap) {
          var knownKeys = Object.keys(qDef.labelMap).filter(function(k) {
            return k !== 'Neuvedeno';
          });
          counts = groupWithFallback(raw, knownKeys, qDef.labelMap);
        } else {
          counts = {};
          Object.keys(raw).forEach(function(k) {
            if (k !== 'Neuvedeno' && k !== '') {
              counts[k] = raw[k];
            }
          });
        }

        var sorted = sortedByFreqDesc(counts);
        var respondents = new Map();
        var labels = sorted.keys.map(function(k) {
          var displayLabel = qDef.labelMap[k] || k;
          respondents.set(displayLabel, leadIndex.get(k) || []);
          return displayLabel;
        });

        var totalResponded = leads.reduce(function(sum, lead) {
          var v = lead[qDef.key];
          if (Array.isArray(v) && v.length > 0) return sum + 1;
          return sum;
        }, 0);

        return { labels: labels, values: sorted.values, totalResponded: totalResponded, respondents: respondents };
      };

      /**
       * Collect free-text responses with author attribution.
       *
       * @param {Array}  leads
       * @param {Object} qDef
       * @returns {{ entries: Array<{text: string, author: string}>, totalResponded: number }}
       */
      QuestionView.aggregateTextField = function(leads, qDef) {
        var entries = [];
        leads.forEach(function(lead) {
          var text = lead[qDef.key];
          if (!text || String(text).trim() === '') return;
          var author = qDef.authorField ? (lead[qDef.authorField] || '') : '';
          entries.push({
            text:   String(text).trim(),
            author: String(author).trim(),
            email:  lead.email || '',
            leadId: lead.id || ''
          });
        });
        return { entries: entries, totalResponded: entries.length };
      };

      /**
       * Dispatcher — routes to the correct aggregation strategy based on qDef.type.
       *
       * @param {Array}  leads
       * @param {Object} qDef
       * @returns {Object} aggregation result appropriate for the question type
       */
      QuestionView.aggregateQuestion = function(leads, qDef) {
        if (qDef.type === 'text')  return QuestionView.aggregateTextField(leads, qDef);
        if (qDef.type === 'multi') return QuestionView.aggregateMultiField(leads, qDef);
        return QuestionView.aggregateSingleField(leads, qDef);
      };

      // ===================================================================
      // Chart instance registry for QuestionView charts
      // ===================================================================

      var qvChartInstances = {};

      QuestionView.destroyChart = function(formKey, qKey) {
        var key = formKey + '_' + qKey;
        if (qvChartInstances[key]) {
          qvChartInstances[key].destroy();
          delete qvChartInstances[key];
        }
      };

      QuestionView.destroyAllChartsForForm = function(formKey) {
        Object.keys(qvChartInstances).forEach(function(key) {
          if (key.indexOf(formKey + '_') === 0 && qvChartInstances[key]) {
            qvChartInstances[key].destroy();
            delete qvChartInstances[key];
          }
        });
      };

      QuestionView.destroyAllCharts = function() {
        Object.keys(qvChartInstances).forEach(function(key) {
          if (qvChartInstances[key]) { qvChartInstances[key].destroy(); }
        });
        qvChartInstances = {};
      };

      // ===================================================================
      // QuestionView chart factories
      // ===================================================================

      /**
       * Build a horizontal bar chart into a QV canvas element.
       *
       * @param {string} formKey  - form identifier key
       * @param {Object} qDef    - question definition from FORM_REGISTRY
       * @param {string[]} labels - human-readable option labels
       * @param {number[]} values - count per label
       */
      QuestionView.buildQvBarChart = function(formKey, qDef, labels, values, respondents) {
        var canvasId    = 'qv-chart-' + formKey + '-' + qDef.key;
        var wrapperId   = 'qv-wrap-'  + formKey + '-' + qDef.key;
        var instanceKey = formKey + '_' + qDef.key;

        setBarWrapperHeight(wrapperId, labels.length);
        QuestionView.destroyChart(formKey, qDef.key);

        var ctx = document.getElementById(canvasId);
        if (!ctx) return;

        var chartColor = qDef.color || getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim() || '#00A39A';

        qvChartInstances[instanceKey] = new Chart(ctx, {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [{
              data: values,
              backgroundColor: chartColor + '66',
              borderColor: chartColor,
              borderWidth: 2,
              borderRadius: 6,
              borderSkipped: false
            }]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            onClick: function(event, elements) {
              if (!elements || elements.length === 0) return;
              var dataIndex = elements[0].index;
              var clickedLabel = labels[dataIndex];
              if (!clickedLabel) return;
              var labelLeads = respondents ? respondents.get(clickedLabel) : null;
              if (!labelLeads || labelLeads.length === 0) return;
              QuestionView.showRespondentPanel(formKey, qDef.key, clickedLabel, labelLeads);
            },
            onHover: function(event, elements) {
              event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    var sum = context.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                    var pct = sum > 0 ? Math.round(context.parsed.x / sum * 100) : 0;
                    return ' ' + context.label + ': ' + context.parsed.x + ' (' + pct + '%)';
                  }
                }
              }
            },
            scales: {
              x: {
                beginAtZero: true,
                ticks: { color: '#6b7280', precision: 0, font: { size: 11 }, maxTicksLimit: 6 },
                grid:  { color: 'rgba(0,0,0,0.04)' },
                border: { display: false }
              },
              y: {
                ticks: { color: '#374151', font: { size: 12 }, autoSkip: false, padding: 8 },
                grid:  { display: false }
              }
            }
          }
        });
      };

      /**
       * Build a doughnut chart into a QV canvas element.
       *
       * @param {string} formKey  - form identifier key
       * @param {Object} qDef    - question definition from FORM_REGISTRY
       * @param {string[]} labels - human-readable option labels
       * @param {number[]} values - count per label
       */
      QuestionView.buildQvDoughnutChart = function(formKey, qDef, labels, values, respondents) {
        var canvasId    = 'qv-chart-' + formKey + '-' + qDef.key;
        var wrapperId   = 'qv-wrap-'  + formKey + '-' + qDef.key;
        var instanceKey = formKey + '_' + qDef.key;

        QuestionView.destroyChart(formKey, qDef.key);

        var ctx = document.getElementById(canvasId);
        if (!ctx) return;

        // Color palette for doughnut segments
        var _primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim() || '#00A39A';
        var palette  = ['#ef4444', '#D4A017', _primaryColor, '#6b7280', '#8b5cf6', '#f97316', '#3b82f6', '#22d3ee'];
        var bgColors = labels.map(function(_, i) { return palette[i % palette.length]; });

        // Fix wrapper height for doughnut (needs more room for the legend)
        var wrapperEl = document.getElementById(wrapperId);
        if (wrapperEl) wrapperEl.style.height = '280px';

        qvChartInstances[instanceKey] = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: labels,
            datasets: [{
              data: values,
              backgroundColor: bgColors,
              borderWidth: 2,
              borderColor: '#ffffff'
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '62%',
            onClick: function(event, elements) {
              if (!elements || elements.length === 0) return;
              var dataIndex = elements[0].index;
              var clickedLabel = labels[dataIndex];
              if (!clickedLabel) return;
              var labelLeads = respondents ? respondents.get(clickedLabel) : null;
              if (!labelLeads || labelLeads.length === 0) return;
              QuestionView.showRespondentPanel(formKey, qDef.key, clickedLabel, labelLeads);
            },
            onHover: function(event, elements) {
              event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
            },
            plugins: {
              legend: {
                position: 'bottom',
                labels: { padding: 16, usePointStyle: true, boxWidth: 10, font: { size: 11 } }
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    var sum = context.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                    var pct = sum > 0 ? Math.round(context.parsed / sum * 100) : 0;
                    return ' ' + context.label + ': ' + context.parsed + ' (' + pct + '%)';
                  }
                }
              }
            }
          }
        });
      };

      // ===================================================================
      // QuestionView freetext renderer
      // ===================================================================

      /**
       * Render a paginated list of free-text responses into a QV container.
       * The first 5 entries are visible; a toggle button reveals the rest.
       * All user content is passed through escapeHtml() before insertion.
       *
       * @param {string} formKey  - form identifier key
       * @param {Object} qDef    - question definition from FORM_REGISTRY
       * @param {Array<{text: string, author: string}>} entries - aggregated text entries
       */
      QuestionView.renderFreetextList = function(formKey, qDef, entries) {
        var containerId = 'qv-freetext-' + formKey + '-' + qDef.key;
        var container   = document.getElementById(containerId);
        if (!container) return;

        if (!entries || entries.length === 0) {
          container.innerHTML = '<div class="gc-empty-field">Žádné textové odpovědi</div>';
          return;
        }

        var maxVisible = 5;
        var html = '';

        entries.forEach(function(entry, i) {
          var hiddenAttr = i >= maxVisible
            ? ' style="display:none;" data-qv-extra="' + formKey + '-' + qDef.key + '"'
            : '';
          html += '<div class="gc-freetext-item"' + hiddenAttr + '>';
          html += '"' + escapeHtml(entry.text) + '"';
          if (entry.author) {
            html += '<div class="gc-freetext-author">— ' + escapeHtml(entry.author) + '</div>';
          }
          html += '</div>';
        });

        if (entries.length > maxVisible) {
          html += '<button class="gc-freetext-toggle" aria-expanded="false" onclick="(function(btn){' +
            'var items=document.querySelectorAll(\'[data-qv-extra=&quot;' + formKey + '-' + qDef.key + '&quot;]\');' +
            'var shown=btn.getAttribute(\'data-shown\')===\'true\';' +
            'items.forEach(function(el){el.style.display=shown?\'none\':\'\';});' +
            'btn.setAttribute(\'data-shown\',shown?\'false\':\'true\');' +
            'btn.setAttribute(\'aria-expanded\',shown?\'false\':\'true\');' +
            'btn.textContent=shown?\'Zobrazit vše (' + entries.length + ')\':\'Skrýt\';' +
            '})(this)">Zobrazit vše (' + entries.length + ')</button>';
        }

        container.innerHTML = html;
      };

      // ===================================================================
      // QuestionView respondent panel
      // ===================================================================

      /**
       * Show (or toggle off) a panel listing the individual respondents who
       * chose a given answer label.  Called by chart onClick handlers.
       *
       * @param {string} formKey   - form identifier key
       * @param {string} qKey     - question key
       * @param {string} label    - the clicked bar / segment label
       * @param {Array}  leadsList - Lead objects that selected this label
       */
      QuestionView.showRespondentPanel = function(formKey, qKey, label, leadsList) {
        var panelId = 'qv-panel-' + formKey + '-' + qKey;
        var panel = document.getElementById(panelId);
        if (!panel) return;

        // Toggle: clicking same bar again hides panel
        var currentLabel = panel.getAttribute('data-active-label');
        if (panel.style.display !== 'none' && currentLabel === label) {
          panel.style.display = 'none';
          panel.removeAttribute('data-active-label');
          return;
        }

        panel.setAttribute('data-active-label', label);

        var count = leadsList.length;
        var countText = count + ' ' + czechPlural(count, 'respondent', 'respondenti', 'respondentů');

        var html = '<div class="gc-respondent-panel__header">';
        html += '<span class="gc-respondent-panel__title">' + escapeHtml(label) + '</span>';
        html += '<span class="gc-respondent-panel__count">' + countText + '</span>';
        html += '<button class="gc-respondent-panel__close" onclick="(function(btn){var p=btn.closest(\'.gc-respondent-panel\');if(p){p.style.display=\'none\';p.removeAttribute(\'data-active-label\');}})(this)" aria-label="Close">&times;</button>';
        html += '</div>';
        html += '<ul class="gc-respondent-list">';

        leadsList.forEach(function(lead) {
          var name = lead.companyName || lead.name || '';
          var email = lead.email || '';
          html += '<li class="gc-respondent-item">';
          // Email as PLAIN TEXT — no mailto link (PII protection)
          html += '<span class="gc-respondent-email">' + escapeHtml(email) + '</span>';
          if (name) {
            html += '<span class="gc-respondent-name">' + escapeHtml(name) + '</span>';
          }
          var date = lead.submittedAt ? new Date(lead.submittedAt).toLocaleDateString('cs-CZ', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
          if (date) {
            html += '<span class="gc-respondent-date">' + date + '</span>';
          }
          html += '</li>';
        });

        html += '</ul>';
        panel.innerHTML = html;
        panel.style.display = 'block';
      };

      // ===================================================================
      // QuestionView sr-only table + keyboard helper
      // ===================================================================

      /**
       * Populate the sr-only data table for a chart and attach a keyboard
       * handler to the canvas so Enter/Space opens the first label's respondents.
       *
       * @param {string} formKey - form identifier key
       * @param {Object} qDef   - question definition from FORM_REGISTRY
       * @param {Object} data   - aggregation result (labels, values, totalResponded, respondents)
       */
      function populateSrTableAndBindKeyboard(formKey, qDef, data) {
        var tableEl = document.getElementById('qv-table-' + formKey + '-' + qDef.key);
        if (tableEl) {
          var tbody = tableEl.querySelector('tbody');
          if (tbody && data.labels) {
            var total2 = data.totalResponded || 0;
            var rows = '';
            for (var ti = 0; ti < data.labels.length; ti++) {
              var pct2 = total2 > 0 ? Math.round(data.values[ti] / total2 * 100) : 0;
              rows += '<tr><td>' + escapeHtml(data.labels[ti]) + '</td><td>' + data.values[ti] + '</td><td>' + pct2 + ' %</td></tr>';
            }
            tbody.innerHTML = rows;
          }
        }
        var canvasEl = document.getElementById('qv-chart-' + formKey + '-' + qDef.key);
        if (canvasEl && data.respondents) {
          canvasEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              var firstLabel = data.labels[0];
              var firstLeads = data.respondents ? data.respondents.get(firstLabel) : null;
              if (firstLeads && firstLeads.length > 0) {
                QuestionView.showRespondentPanel(formKey, qDef.key, firstLabel, firstLeads);
              }
            }
          });
        }
      }

      // ===================================================================
      // QuestionView block renderer — top-level dispatcher
      // ===================================================================

      /**
       * Render a single question block: aggregate data, update the response
       * bar, then delegate to the appropriate chart or freetext renderer.
       *
       * Dispatch rules:
       *   type === 'text'  → renderFreetextList
       *   type === 'multi' → buildQvBarChart  (always horizontal bar)
       *   otherwise        → buildQvDoughnutChart when qDef.chartType === 'doughnut',
       *                      else buildQvBarChart
       *
       * @param {string} formKey  - form identifier key
       * @param {Object} qDef    - question definition from FORM_REGISTRY
       * @param {number} qNumber - 1-based question index (reserved for future use)
       * @param {Array}  leads   - filtered lead array for this form
       */
      QuestionView.renderQuestionBlock = function(formKey, qDef, qNumber, leads) {
        var data = QuestionView.aggregateQuestion(leads, qDef);

        var countEl  = document.getElementById('qv-count-'     + formKey + '-' + qDef.key);
        var barFill  = document.getElementById('qv-bar-'       + formKey + '-' + qDef.key);
        var barLabel = document.getElementById('qv-bar-label-' + formKey + '-' + qDef.key);

        if (qDef.type === 'text') {
          var responded = data.totalResponded;
          var total     = leads.length;
          var pct       = total > 0 ? Math.round(responded / total * 100) : 0;

          if (countEl)  countEl.textContent      = responded + ' odpovědí';
          if (barFill)  barFill.style.width      = pct + '%';
          if (barLabel) barLabel.textContent     = responded + ' z ' + total + ' respondentů (' + pct + '%)';
          var barContainer = barFill ? barFill.parentElement : null;
          if (barContainer) { barContainer.setAttribute('aria-valuenow', Math.round(pct)); }

          QuestionView.renderFreetextList(formKey, qDef, data.entries);

        } else if (qDef.type === 'multi') {
          var totalSelections = data.values.reduce(function(a, b) { return a + b; }, 0);
          var responded = data.totalResponded;
          var total     = leads.length;
          var pct       = total > 0 ? Math.round(responded / total * 100) : 0;

          if (countEl)  countEl.textContent  = totalSelections + ' výběrů od ' + responded + ' respondentů';
          if (barFill)  barFill.style.width  = pct + '%';
          if (barLabel) barLabel.textContent = responded + ' z ' + total + ' respondentů (' + pct + '%)';
          var barContainer = barFill ? barFill.parentElement : null;
          if (barContainer) { barContainer.setAttribute('aria-valuenow', Math.round(pct)); }

          if (data.labels.length > 0) {
            QuestionView.buildQvBarChart(formKey, qDef, data.labels, data.values, data.respondents);
            populateSrTableAndBindKeyboard(formKey, qDef, data);
          }

        } else {
          // single or ordinal
          var responded = data.totalResponded;
          var total     = leads.length;
          var pct       = total > 0 ? Math.round(responded / total * 100) : 0;

          if (countEl)  countEl.textContent  = responded + ' odpovědí z ' + total;
          if (barFill)  barFill.style.width  = pct + '%';
          if (barLabel) barLabel.textContent = responded + ' z ' + total + ' respondentů (' + pct + '%)';
          var barContainer = barFill ? barFill.parentElement : null;
          if (barContainer) { barContainer.setAttribute('aria-valuenow', Math.round(pct)); }

          if (data.labels.length > 0) {
            if (qDef.chartType === 'doughnut') {
              QuestionView.buildQvDoughnutChart(formKey, qDef, data.labels, data.values, data.respondents);
              populateSrTableAndBindKeyboard(formKey, qDef, data);
            } else {
              QuestionView.buildQvBarChart(formKey, qDef, data.labels, data.values, data.respondents);
              populateSrTableAndBindKeyboard(formKey, qDef, data);
            }
          }
        }
      };

      // ===================================================================
      // QuestionView HTML builder
      // ===================================================================

      /**
       * Generates the complete HTML string for a form's Question View.
       * Uses only existing .gc-* CSS classes — no new classes are introduced.
       *
       * @param {string} formKey  - form identifier key
       * @param {Object} formDef  - form definition from FORM_REGISTRY
       * @returns {string} HTML string ready for innerHTML assignment
       */
      QuestionView.buildQvHTML = function(formKey, formDef) {
        var html = '<div class="gc-analytics-container">';

        // Summary bar placeholder — populated by renderQvSummaryBar after DOM insertion
        html += '<div class="gc-summary-bar" id="qv-summary-' + formKey + '"></div>';

        // Track question number across all sections
        var qNum = 0;

        // Section accent colours matching the GC analytics palette
        var sectionColors = { A: '#00C4B4', B: '#f97316', C: '#6366f1', D: '#22d3ee' };

        // Pre-scan: count how many questions belong to each section
        var sectionCounts = {};
        formDef.questions.forEach(function(q) {
          var sid = q.section || 'A';
          sectionCounts[sid] = (sectionCounts[sid] || 0) + 1;
        });

        // Pre-scan for 2-column grid groups
        var gridGroups = [];
        var gi = 0;
        while (gi < formDef.questions.length) {
          var gq = formDef.questions[gi];
          var isSmall = gq.chartType !== 'none' && gq.orderedKeys && gq.orderedKeys.length <= 4;
          if (isSmall) {
            var groupStart = gi;
            var groupSection = gq.section;
            while (gi + 1 < formDef.questions.length) {
              var nextQ = formDef.questions[gi + 1];
              var nextSmall = nextQ.chartType !== 'none' && nextQ.orderedKeys && nextQ.orderedKeys.length <= 4;
              if (nextSmall && nextQ.section === groupSection) {
                gi++;
              } else {
                break;
              }
            }
            if (gi > groupStart) {
              gridGroups.push([groupStart, gi]);
            }
          }
          gi++;
        }
        var gridStarts = {};
        var gridEnds = {};
        gridGroups.forEach(function(g) {
          gridStarts[g[0]] = true;
          gridEnds[g[1]] = true;
        });

        // Track current section so headers are only emitted once per section
        var currentSection = null;

        for (var qi = 0; qi < formDef.questions.length; qi++) {
          var q = formDef.questions[qi];
          qNum++;

          // Emit a section header whenever the section changes
          if (q.section !== currentSection) {
            currentSection = q.section;
            var sectionDef = null;
            formDef.sections.forEach(function(s) { if (s.id === currentSection) sectionDef = s; });
            if (sectionDef) {
              var sectionId = sectionDef.id;
              var sectionClass = 'gc-section-header gc-section-header--' + sectionId.toLowerCase();
              if (qNum === 1) sectionClass += ' gc-section-header--first';
              var sectionN = sectionCounts[sectionId] || 0;
              var sectionCountLabel = czechPlural(sectionN, 'otázka', 'otázky', 'otázek');
              html += '<div class="' + sectionClass + '" aria-label="Sekce ' + escapeHtml(sectionId) + ': ' + escapeHtml(sectionDef.title) + '">';
              html += '<span class="gc-section-badge">' + escapeHtml(sectionId) + '</span>';
              html += '<h3>' + escapeHtml(sectionDef.title) + '</h3>';
              html += '<span class="gc-section-count">' + sectionN + ' ' + sectionCountLabel + '</span>';
              html += '</div>';
            }
          }

          // Open 2-column grid wrapper if this question starts a grid group
          if (gridStarts[qi]) {
            html += '<div class="gc-question-grid-2col">';
          }

          // Badge and type label classes
          var isRequired     = q.required;
          var badgeClass     = 'gc-q-badge' + (isRequired ? ' gc-q-badge--required' : ' gc-q-badge--optional');
          var typeLabel      = q.type === 'multi' ? 'Více výběrů' : (q.type === 'text' ? 'Text' : 'Jeden výběr');
          var typeBadgeClass = 'gc-type-badge' + (q.type === 'multi' ? ' gc-type-badge--multi' : q.type === 'text' ? ' gc-type-badge--text' : ' gc-type-badge--single');

          html += '<div class="gc-question-block gc-question-block--section-' + (q.section || 'a').toLowerCase() + '">';

          // Row 1: badge + title headline
          html += '<div class="gc-question-header">';
          html += '<span class="' + badgeClass + '">Q' + qNum + '</span>';
          html += '<h4 class="gc-question-title">' + escapeHtml(q.title) + '</h4>';
          html += '</div>';

          // Row 2: metadata strip (type + response count)
          html += '<div class="gc-question-meta">';
          html += '<span class="' + typeBadgeClass + '">' + escapeHtml(typeLabel) + '</span>';
          html += '<span class="gc-response-count" id="qv-count-' + formKey + '-' + q.key + '">–</span>';
          html += '</div>';

          // Thin divider line
          html += '<div class="gc-question-divider"></div>';

          // Response bar — filled by renderQuestionBlock after data aggregation
          html += '<div class="gc-response-bar" role="progressbar" aria-label="M\u00edra odpov\u011bd\u00ed" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"><div class="gc-response-bar-fill" id="qv-bar-' + formKey + '-' + q.key + '" style="width: 0%;"></div></div>';
          html += '<div class="gc-response-bar-label" id="qv-bar-label-' + formKey + '-' + q.key + '"></div>';

          // Chart container or freetext list depending on chartType
          if (q.chartType === 'none') {
            html += '<div class="gc-freetext-list" id="qv-freetext-' + formKey + '-' + q.key + '"></div>';
          } else {
            html += '<div class="gc-chart-wrapper" id="qv-wrap-' + formKey + '-' + q.key + '" style="position: relative;">';
            // role="img" + aria-label satisfy WCAG for canvas-based charts
            html += '<canvas id="qv-chart-' + formKey + '-' + q.key + '" role="img" aria-label="Graf: ' + escapeHtml(q.title) + '" aria-describedby="qv-table-' + formKey + '-' + q.key + '" tabindex="0"></canvas>';
            html += '<span class="sr-only">Stiskn\u011bte Enter pro zobrazen\u00ed respondent\u016f prvn\u00ed odpov\u011bdi</span>';
            html += '</div>';
            html += '<table id="qv-table-' + formKey + '-' + q.key + '" class="sr-only">';
            html += '<caption>' + escapeHtml(q.label || q.title) + ' \u2014 distribuce odpov\u011bd\u00ed</caption>';
            html += '<thead><tr><th>Odpov\u011b\u010f</th><th>Po\u010det</th><th>Procento</th></tr></thead>';
            html += '<tbody></tbody>';
            html += '</table>';
            html += '<div class="gc-respondent-panel" id="qv-panel-' + formKey + '-' + q.key + '" style="display:none;" aria-live="polite"></div>';
          }

          html += '</div>'; // close .gc-question-block

          // Close 2-column grid wrapper if this question ends a grid group
          if (gridEnds[qi]) {
            html += '</div>'; // close gc-question-grid-2col
          }
        }

        html += '</div>'; // close .gc-analytics-container
        return html;
      };

      // ===================================================================
      // QuestionView master renderer
      // ===================================================================

      /**
       * Master orchestrator for the Question View panel.
       * Destroys stale charts, filters leads for the requested form,
       * injects HTML, renders the summary bar, then renders every
       * question block in document order.
       *
       * IMPORTANT ordering contract:
       *   1. destroyAllCharts()  — must happen BEFORE innerHTML replacement
       *   2. innerHTML = …       — wipes the DOM, creates fresh canvas elements
       *   3. renderQvSummaryBar  — populates the summary bar element
       *   4. renderQuestionBlock — must happen AFTER innerHTML (needs canvas in DOM)
       *
       * @param {string} formKey - form identifier key from FORM_REGISTRY
       */
      QuestionView.renderQuestionView = function(formKey) {
        var formDef = FORM_REGISTRY[formKey];
        if (!formDef) return;

        var contentEl = document.getElementById('qv-content');
        if (!contentEl) return;

        // Step 1 — destroy all chart instances BEFORE innerHTML replacement
        // (Chart.js holds canvas references; destroying first prevents memory leaks)
        QuestionView.destroyAllCharts();

        // Step 2 — filter leads to only those belonging to this form
        // Apply date and platform filters from the global filter bar
        var leads = getFilteredLeads({ applySearch: false, applySource: false }).filter(formDef.leadFilter);

        // Empty state: no leads at all
        if (leads.length === 0) {
          contentEl.innerHTML = '<div class="qv-empty-state">' +
            '<iconify-icon icon="solar:inbox-line-bold" width="64" style="color: #d1d5db; display: block; margin: 0 auto 1rem;"></iconify-icon>' +
            '<p style="font-size: 1rem; font-weight: 500; color: #6b7280;">Žádné odpovědi pro formulář \u201e' + escapeHtml(formDef.label) + '\u201c</p>' +
            '</div>';
          return;
        }

        // Below-threshold state: not enough data to render meaningful charts
        if (leads.length < formDef.minDataThreshold) {
          contentEl.innerHTML = '<div class="qv-empty-state">' +
            '<iconify-icon icon="solar:chart-square-line-duotone" width="64" style="color: #d1d5db; display: block; margin: 0 auto 1rem;"></iconify-icon>' +
            '<p style="font-size: 1rem; font-weight: 500; color: #6b7280;">Nedostatek dat pro analýzu</p>' +
            '<p style="font-size: 0.8125rem; color: #9ca3af;">Formulář \u201e' + escapeHtml(formDef.label) + '\u201c má ' + leads.length + ' odpov\u011bd' + (leads.length === 1 ? '\u011b' : 'i') + '. Minimum pro grafy: ' + formDef.minDataThreshold + '.</p>' +
            '</div>';
          return;
        }

        // Step 3 — generate and inject HTML (creates all canvas/container elements)
        contentEl.innerHTML = QuestionView.buildQvHTML(formKey, formDef);

        // Step 4 — populate the summary bar (DOM element now exists)
        QuestionView.renderQvSummaryBar(formKey, leads, formDef);

        // Step 5 — render each question block (canvas elements now exist in DOM)
        var qNum = 0;
        formDef.questions.forEach(function(q) {
          qNum++;
          QuestionView.renderQuestionBlock(formKey, q, qNum, leads);
        });

        // Mark this form as rendered in the shared UI state
        QV_STATE.chartsRendered[formKey] = true;
      };

      // ===================================================================
      // QuestionView summary bar renderer
      // ===================================================================

      /**
       * Populates the summary bar (#qv-summary-{formKey}) with aggregate
       * statistics: total respondents, submission date range, and a
       * form-specific contextual stat (top service or top industry).
       *
       * @param {string} formKey  - form identifier key
       * @param {Array}  leads    - filtered lead array for this form (length > 0 guaranteed)
       * @param {Object} formDef  - form definition from FORM_REGISTRY
       */
      QuestionView.renderQvSummaryBar = function(formKey, leads, formDef) {
        var summaryEl = document.getElementById('qv-summary-' + formKey);
        if (!summaryEl || leads.length === 0) return;

        var total = leads.length;

        // Derive submission date range from submittedAt timestamps
        var dates = leads.map(function(l) { return new Date(l.submittedAt); }).filter(function(d) { return !isNaN(d); });
        var earliest = dates.length > 0 ? new Date(Math.min.apply(null, dates)) : null;
        var latest   = dates.length > 0 ? new Date(Math.max.apply(null, dates)) : null;

        var formatDate = function(d) {
          if (!d) return '\u2013';
          return d.toLocaleDateString('cs-CZ', { day: '2-digit', month: '2-digit', year: 'numeric' });
        };

        // Build a form-specific contextual stat for the right-hand side of the bar
        var contextStat = '';
        if (formKey === 'contact') {
          // Contact form: show most-selected service
          var serviceCounts = {};
          leads.forEach(function(l) { if (l.service) serviceCounts[l.service] = (serviceCounts[l.service] || 0) + 1; });
          var topService = Object.entries(serviceCounts).sort(function(a, b) { return b[1] - a[1]; })[0];
          if (topService) {
            var serviceQ      = (FORM_REGISTRY.contact.questions.find(function(q) { return q.key === 'service'; }) || {});
            var serviceLblMap = serviceQ.labelMap || {};
            contextStat = 'Nejčastější služba: ' + escapeHtml(serviceLblMap[topService[0]] || topService[0]);
          }
        } else {
          // All other forms: show most common industry
          var indField  = formKey === 'audit' ? 'detectedIndustry' : 'industry';
          var indCounts = {};
          leads.forEach(function(l) { if (l[indField]) indCounts[l[indField]] = (indCounts[l[indField]] || 0) + 1; });
          var topInd = Object.entries(indCounts).sort(function(a, b) { return b[1] - a[1]; })[0];
          if (topInd) {
            contextStat = 'Nejčastější odvětví: ' + escapeHtml(INDUSTRY_LABELS[topInd[0]] || topInd[0]);
          }
        }

        var html = '<div style="display: flex; align-items: center; flex-wrap: wrap; gap: 0.75rem;">';
        html += '<span style="font-weight: 600; color: #111827; font-size: 0.9375rem;">Celkem: ' + total + ' respondent\u016f</span>';
        html += '<span class="gc-summary-divider" style="color: #d1d5db; margin: 0 0.25rem;">|</span>';
        html += '<span style="color: #6b7280; font-size: 0.8125rem;">Od: ' + formatDate(earliest) + ' \u2013 Do: ' + formatDate(latest) + '</span>';
        if (contextStat) {
          html += '<span class="gc-summary-divider" style="color: #d1d5db; margin: 0 0.25rem;">|</span>';
          html += '<span style="color: #6b7280; font-size: 0.8125rem;">' + contextStat + '</span>';
        }
        html += '</div>';

        summaryEl.innerHTML = html;
      };

      // ===================================================================
      // VIEW TOGGLE WIRING
      // ===================================================================

      var btnTableView = document.getElementById('btn-table-view');
      var btnQuestionView = document.getElementById('btn-question-view');
      var qvFormSelector = document.getElementById('qv-form-selector');
      var qvFormSelect = document.getElementById('qv-form-select');
      var questionViewPanel = document.getElementById('question-view-panel');

      function activateTableView() {
        QV_STATE.visible = false;
        var f = document.querySelector('.filters');
        var t = document.querySelector('.table-container');
        if (f) f.style.display = '';
        if (t) t.style.display = '';
        if (questionViewPanel) questionViewPanel.style.display = 'none';
        if (qvFormSelector) qvFormSelector.style.display = 'none';
        if (btnTableView) btnTableView.classList.add('active');
        if (btnQuestionView) btnQuestionView.classList.remove('active');
        QuestionView.destroyAllCharts();
      }

      function activateQuestionView(preselectedFormKey) {
        QV_STATE.visible = true;
        var f = document.querySelector('.filters');
        var t = document.querySelector('.table-container');
        if (f) f.style.display = 'none';
        if (t) t.style.display = 'none';
        if (questionViewPanel) questionViewPanel.style.display = '';
        if (qvFormSelector) qvFormSelector.style.display = '';
        if (btnTableView) btnTableView.classList.remove('active');
        if (btnQuestionView) btnQuestionView.classList.add('active');
        if (preselectedFormKey && qvFormSelect) {
          qvFormSelect.value = preselectedFormKey;
          QV_STATE.activeFormKey = preselectedFormKey;
          QuestionView.renderQuestionView(preselectedFormKey);
        } else if (QV_STATE.activeFormKey) {
          QuestionView.renderQuestionView(QV_STATE.activeFormKey);
        }
      }

      if (btnTableView) btnTableView.addEventListener('click', function() { window.location.hash = ''; activateTableView(); });
      if (btnQuestionView) btnQuestionView.addEventListener('click', function() { window.location.hash = '#question-view'; activateQuestionView(); });

      if (qvFormSelect) {
        qvFormSelect.addEventListener('change', function() {
          var formKey = qvFormSelect.value;
          if (formKey) {
            QV_STATE.activeFormKey = formKey;
            QV_STATE.chartsRendered[formKey] = false;
            window.location.hash = '#question-view/' + formKey;
            QuestionView.renderQuestionView(formKey);
          } else {
            QV_STATE.activeFormKey = null;
            QuestionView.destroyAllCharts();
            var c = document.getElementById('qv-content');
            if (c) c.innerHTML = '<div class="qv-empty-state"><iconify-icon icon="solar:chart-square-line-duotone" width="64" style="color:#d1d5db;display:block;margin:0 auto 1rem;"></iconify-icon><p style="font-size:1rem;font-weight:500;color:#6b7280;margin-bottom:0.5rem;">Vyberte formulář pro zobrazení analýzy odpovědí</p><p style="font-size:0.8125rem;color:#9ca3af;">Zvolte typ formuláře z výběru nahoře</p></div>';
          }
        });
      }

      // Re-render QV when date/platform filters change
      [filterFrom, filterTo, filterPlatform].forEach(function(el) {
        if (el) el.addEventListener('change', function() {
          if (QV_STATE.visible && QV_STATE.activeFormKey) {
            QV_STATE.chartsRendered[QV_STATE.activeFormKey] = false;
            QuestionView.renderQuestionView(QV_STATE.activeFormKey);
          }
        });
      });

      // ===================================================================
      // DELETE FUNCTIONALITY
      // ===================================================================
      
      const deleteSelectedBtn = document.getElementById('delete-selected-btn');
      const selectedCountSpan = document.getElementById('selected-count');
      const selectAllCheckbox = document.getElementById('select-all');
      const deleteModal = document.getElementById('delete-modal');
      const deleteModalCount = document.getElementById('delete-modal-count');
      const deleteCancelBtn = document.getElementById('delete-cancel-btn');
      const deleteConfirmBtn = document.getElementById('delete-confirm-btn');
      const deleteReportsCheckbox = document.getElementById('delete-reports-checkbox');
      
      let selectedLeads = new Set();
      
      // Update selected count and button state
      function updateDeleteButtonState() {
        const count = selectedLeads.size;
        selectedCountSpan.textContent = count;
        deleteSelectedBtn.disabled = count === 0;
      }
      
      // Handle individual checkbox clicks
      document.addEventListener('change', function(e) {
        if (e.target.classList.contains('lead-checkbox')) {
          const leadId = e.target.dataset.id;
          const row = e.target.closest('tr');
          
          if (e.target.checked) {
            selectedLeads.add(leadId);
            row.classList.add('selected');
          } else {
            selectedLeads.delete(leadId);
            row.classList.remove('selected');
          }
          
          updateDeleteButtonState();
          
          // Update select-all checkbox state
          const allCheckboxes = document.querySelectorAll('.lead-checkbox');
          const checkedCheckboxes = document.querySelectorAll('.lead-checkbox:checked');
          selectAllCheckbox.checked = allCheckboxes.length > 0 && allCheckboxes.length === checkedCheckboxes.length;
          selectAllCheckbox.indeterminate = checkedCheckboxes.length > 0 && checkedCheckboxes.length < allCheckboxes.length;
        }
      });
      
      // Handle select-all checkbox
      selectAllCheckbox.addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('.lead-checkbox');
        const rows = document.querySelectorAll('#leads-tbody tr');
        
        selectedLeads.clear();
        
        checkboxes.forEach((checkbox, index) => {
          checkbox.checked = selectAllCheckbox.checked;
          if (selectAllCheckbox.checked) {
            selectedLeads.add(checkbox.dataset.id);
            rows[index].classList.add('selected');
          } else {
            rows[index].classList.remove('selected');
          }
        });
        
        updateDeleteButtonState();
      });
      
      // Show delete modal
      deleteSelectedBtn.addEventListener('click', function() {
        if (selectedLeads.size === 0) return;
        
        const count = selectedLeads.size;
        deleteModalCount.textContent = `Opravdu chcete smazat ${count} ${count === 1 ? 'lead' : count < 5 ? 'leady' : 'leadů'}?`;
        deleteModal.style.display = 'flex';
      });
      
      // Cancel delete
      deleteCancelBtn.addEventListener('click', function() {
        deleteModal.style.display = 'none';
      });
      
      // Close modal on backdrop click
      deleteModal.addEventListener('click', function(e) {
        if (e.target === deleteModal) {
          deleteModal.style.display = 'none';
        }
      });
      
      // Confirm delete
      deleteConfirmBtn.addEventListener('click', async function() {
        const leadIds = Array.from(selectedLeads);
        const deleteReports = deleteReportsCheckbox.checked;
        
        if (leadIds.length === 0) return;
        
        // Disable button during deletion
        deleteConfirmBtn.disabled = true;
        deleteConfirmBtn.innerHTML = '<iconify-icon icon="svg-spinners:ring-resize"></iconify-icon> Mazání...';
        
        try {
          const response = await fetch('/.netlify/functions/admin-leads-delete', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + password
            },
            body: JSON.stringify({
              leadIds: leadIds,
              deleteReports: deleteReports
            })
          });

          if (response.status === 401) {
            deleteModal.style.display = 'none';
            handleAuthFailure('Relace vypršela. Přihlaste se znovu.');
            return;
          }

          const result = await response.json();

          if (response.ok && result.success) {
            console.log(`[Delete] Successfully deleted ${result.deletedCount} leads`);
            
            // Close modal
            deleteModal.style.display = 'none';
            
            // Clear selection
            selectedLeads.clear();
            selectAllCheckbox.checked = false;
            updateDeleteButtonState();
            
            // Refresh leads list
            await fetchLeads();
            
            // Show success message (optional)
            if (result.errors.length > 0) {
              console.warn(`[Delete] ${result.errors.length} errors occurred:`, result.errors);
            }
          } else {
            console.error('[Delete] Failed:', result.error || 'Unknown error');
            alert('Nepodařilo se smazat leady. Zkuste to znovu.');
          }
        } catch (error) {
          console.error('[Delete] Error:', error);
          alert('Došlo k chybě při mazání leadů.');
        } finally {
          // Re-enable button
          deleteConfirmBtn.disabled = false;
          deleteConfirmBtn.innerHTML = '<iconify-icon icon="solar:trash-bin-trash-bold"></iconify-icon> Smazat';
        }
      });
      // --- Data aggregation helpers ---
      function countField(leads, field) {
        return leads.reduce(function(acc, lead) {
          var val = lead[field] || 'Neuvedeno';
          if (val === '') val = 'Neuvedeno';
          acc[val] = (acc[val] || 0) + 1;
          return acc;
        }, {});
      }

      function countArrayField(leads, field) {
        return leads.reduce(function(acc, lead) {
          var values = lead[field];
          if (Array.isArray(values)) {
            values.forEach(function(v) {
              if (v) acc[v] = (acc[v] || 0) + 1;
            });
          }
          return acc;
        }, {});
      }

      function indexLeadsByField(leads, field) {
        var index = new Map();
        leads.forEach(function(lead) {
          var val = lead[field];
          if (!val || val === '' || val === 'Neuvedeno') return;
          if (!index.has(val)) index.set(val, []);
          index.get(val).push(lead);
        });
        return index;
      }

      function indexLeadsByArrayField(leads, field) {
        var index = new Map();
        leads.forEach(function(lead) {
          var values = lead[field];
          if (!Array.isArray(values)) return;
          values.forEach(function(v) {
            if (!v) return;
            if (!index.has(v)) index.set(v, []);
            index.get(v).push(lead);
          });
        });
        return index;
      }

      function czechPlural(n, one, few, many) {
        if (n === 1) return one;
        if (n >= 2 && n <= 4) return few;
        return many;
      }

      function sortedByFreqDesc(obj) {
        var entries = Object.entries(obj).sort(function(a, b) { return b[1] - a[1]; });
        return {
          keys: entries.map(function(e) { return e[0]; }),
          values: entries.map(function(e) { return e[1]; })
        };
      }

      function applyGlobalChartDefaults() {
        if (typeof Chart === 'undefined') return;
        Chart.defaults.color = CHART_DEFAULTS.color;
        Chart.defaults.font.family = CHART_DEFAULTS.font.family;
        Chart.defaults.font.size = CHART_DEFAULTS.font.size;
      }

      function setBarWrapperHeight(wrapperId, itemCount) {
        var wrapper = document.getElementById(wrapperId);
        if (wrapper) {
          var h = Math.max(220, itemCount * 36);
          wrapper.style.height = h + 'px';
        }
      }

      // Group unknown values under "Ostatní", keeping known ones labelled
      function groupWithFallback(rawCounts, knownKeys, labelMap) {
        var grouped = {};
        Object.keys(rawCounts).forEach(function(k) {
          if (k === 'Neuvedeno' || k === '') return;
          if (knownKeys.indexOf(k) === -1) {
            grouped['other'] = (grouped['other'] || 0) + rawCounts[k];
          } else {
            grouped[k] = (grouped[k] || 0) + rawCounts[k];
          }
        });
        return grouped;
      }

      // GC Event stat card click
      var gcEventStatCard = document.getElementById('stat-card-gc-event');
      if (gcEventStatCard) {
        gcEventStatCard.addEventListener('click', function() {
          activateQuestionView('gc-event');
        });
      }

      var otherStatCards = document.querySelectorAll('.stat-card:not(#stat-card-gc-event)');
      otherStatCards.forEach(function(card) {
        card.addEventListener('click', function() { activateTableView(); });
      });

      // Hash-based activation on page load (run after fetchLeads completes)
      function checkHashActivation() {
        var hash = window.location.hash;
        if (hash === '#gc-event' || hash === '#question-view/gc-event') {
          activateQuestionView('gc-event');
        } else if (hash === '#question-view/audit') {
          activateQuestionView('audit');
        } else if (hash === '#question-view/contact') {
          activateQuestionView('contact');
        } else if (hash === '#question-view/survey') {
          activateQuestionView('survey');
        } else if (hash === '#question-view') {
          activateQuestionView();
        }
      }

      var _originalFetchLeads = fetchLeads;
      fetchLeads = async function() {
        var result = await _originalFetchLeads.apply(this, arguments);
        if (result) checkHashActivation();
        return result;
      };

    })();
  </script>
</body>
</html>
