      // Export CSV
      exportBtn.addEventListener('click', () => {
        if (allLeads.length === 0) return;
        
        const headers = ['Datum', 'Zdroj', 'Formulář', 'Platforma', 'Medium', 'Kampaň', 'Email', 'Firma/Jméno', 'Web', 'Město', 'Telefon', 'Služba', 'Report URL', 'Jazyk', 'GCLID', 'FBCLID', 'Referrer', 'Industry', 'Company Size', 'Pain Points', 'Primary Pain Point', 'AI Maturity', 'Hours Lost/Week', 'Context Note', 'Pouzivane nastroje', 'Tech Level', 'Top Examples'];
        function csvSafeValue(val) {
          let str = String(val || '').replace(/"/g, '""');
          if (/^[=+\-@\t\r]/.test(str)) {
            str = "'" + str;
          }
          return '"' + str + '"';
        }

        const rows = allLeads.map(lead => {
          const date = new Date(lead.submittedAt).toISOString();
          const nameField = lead.source === 'audit' ? (lead.companyName || '') : (lead.source === 'survey' ? (lead.companyName || lead.name || '') : (lead.name || ''));
          return [
            date,
            lead.source,
            lead.leadSource || '',
            lead.utmSource || '',
            lead.utmMedium || '',
            lead.utmCampaign || '',
            lead.email,
            nameField,
            lead.source === 'survey' ? '' : (lead.website || ''),
            lead.city || '',
            lead.phoneNumber || lead.phone || '',
            lead.service || '',
            lead.reportUrl || '',
            lead.language || '',
            lead.gclid || '',
            lead.fbclid || '',
            lead.referrer || '',
            lead.source === 'survey' ? (lead.industry || '') : '',
            lead.source === 'survey' ? (lead.companySize || '') : '',
            lead.source === 'survey' ? (lead.painPoints ? lead.painPoints.join('; ') : '') : '',
            lead.source === 'survey' ? (lead.primaryPainPoint || '') : '',
            lead.source === 'survey' ? (lead.aiMaturity || '') : '',
            lead.source === 'survey' ? (lead.hoursLostPerWeek || '') : '',
            lead.source === 'survey' ? (lead.contextNote || '') : '',
            lead.source === 'survey' ? ((lead.toolsUsed || []).join(', ') || '-') : '',
            lead.source === 'survey' ? (lead.techLevel || '') : '',
            lead.source === 'survey' ? ((lead.topExamples || []).join(', ') || '') : ''
          ].map(csvSafeValue).join(',');
        });
        
        const csv = [headers.join(','), ...rows].join('\n');
        const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `leads_export_${new Date().toISOString().split('T')[0]}.csv`;
        link.click();
        URL.revokeObjectURL(url);
      });

